{
  "name": "codenexai-documentation",
  "displayName": "CodeNexAI Document your code",
  "description": "Select code in your editor to generate documentation using CodenexAI.",
  "version": "0.1.3",
  "publisher": "CodeNexAI",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onCommand:codenexai.generateDocumentation",
    "onCommand:codenexai.login",
    "onCommand:codenexai.logout",
    "onCommand:codenexai.codeReview",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codenexai.generateDocumentation",
        "title": "CodenexAI: Generate Documentation for Selection",
        "category": "CodenexAI"
      },
      {
        "command": "codenexai.login",
        "title": "CodenexAI: Login",
        "category": "CodenexAI"
      },
      {
        "command": "codenexai.logout",
        "title": "CodenexAI: Logout",
        "category": "CodenexAI"
      },
      {
        "command": "codenexai.codeReview",
        "title": "CodenexAI: Code Review",
        "category": "CodenexAI"
      },
      {
        "command": "codenexai.reviewDiff",
        "title": "CodenexAI: Review Diff",
        "category": "CodenexAI"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "codenexai.generateDocumentation",
          "group": "navigation"
        }
      ]
    }
  },
  "configuration": {
    "title": "CodeNexAI",
    "properties": {
      "codenexai.reviewInstructions": {
        "type": "string",
        "default": "Detect and fix functional bugs, code smells, missed unit tests, and security vulnerabilities.",
        "description": "Custom instructions for the code review."
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix"
  },
  "devDependencies": {
    "@types/babel__parser": "^7.1.5",
    "@types/markdown-it": "^13.0.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.5.3",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "markdown-it": "^14.0.0"
  },
  "icon": "images/icon.png"
}
