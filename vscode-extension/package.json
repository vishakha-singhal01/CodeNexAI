{
  "name": "codenexai-documentation",
  "displayName": "CodeNexAI Document your code",
  "description": "Select code in your editor to generate documentation using CodenexAI.",
  "version": "0.1.3",
  "publisher": "CodeNexAI",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education",
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onCommand:codenexai.generateDocumentation",
    "onCommand:codenexai.login",
    "onCommand:codenexai.logout",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codenexai.generateDocumentation",
        "title": "CodenexAI: Generate Documentation for Selection",
        "category": "CodenexAI"
      },
      {
        "command": "codenexai.login",
        "title": "CodenexAI: Login",
        "category": "CodenexAI"
      },
      {
        "command": "codenexai.logout",
        "title": "CodenexAI: Logout",
        "category": "CodeNexAI"
      },
      {
        "command": "codenexai.analyzeSecurity",
        "title": "CodenexAI: Analyze Security",
        "category": "CodeNexAI"
      },
      {
        "command": "codenexai.showCodeReview",
        "title": "CodenexAI: Show Code Review",
        "category": "CodeNexAI"
      }
    ],
    "menus": {
      "commandpalette": [
        {
          "command": "codenexai.showCodeReview",
          "when": "true"
        }
      ],
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "codenexai.generateDocumentation",
          "group": "navigation"
        },
        {
          "when": "editorHasSelection",
          "command": "codenexai.analyzeSecurity",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codenexai",
          "title": "CodeNexAI",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "codenexai": [
        {
          "id": "documentation",
          "name": "Documentation",
          "when": "view == codenexai"
        },
        {
          "id": "codeReview",
          "name": "Code Review",
          "when": "view == codenexai"
        },
        {
          "id": "securityAnalysis",
          "name": "Security Analysis",
          "when": "view == codenexai"
        }
      ]
    },
    "configuration": {
      "title": "CodeNexAI",
      "properties": {
        "codenexai.geminiApiKey": {
          "type": "string",
          "description": "Your Gemini API key"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/babel__parser": "^7.1.5",
    "@types/markdown-it": "^13.0.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.57.1",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "markdown-it": "^14.0.0",
    "@google/generative-ai": "^0.7.0"
  },
  "icon": "images/icon.png"
}
