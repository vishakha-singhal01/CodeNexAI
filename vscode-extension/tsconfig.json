{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020", // Target a reasonably modern ES version
    "outDir": "dist", // Output compiled JS to a 'dist' folder
    "rootDir": "src", // Source files are in 'src'
    "lib": [
      "ES2020"
    ],
    "types": [ // Explicitly include core types
      "node",
      "vscode"
    ],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true, // Allows for 'import * as vscode from "vscode"'
    "skipLibCheck": true, // Skip type checking of declaration files
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true // Allows importing JSON files
  },
  "include": [
    "src/**/*.ts" // Only compile .ts files in the src directory
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
